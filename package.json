{
  "name": "xeno-crm",
  "private": true,
  "scripts": {
    "dev": "turbo run dev worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "worker": "turbo run worker",
    "db:migrate": "pnpm --filter crm prisma migrate dev",
    "db:migrate-vectors": "pnpm --filter crm exec psql $DATABASE_URL -f prisma/migrations/add-vector-columns.sql",
    "db:seed": "pnpm --filter crm prisma db seed",
    "db:studio": "pnpm --filter crm prisma studio",
    "db:reset": "pnpm --filter crm prisma migrate reset --force && pnpm db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}


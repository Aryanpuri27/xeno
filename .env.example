# Database (local Docker)
DATABASE_URL="postgresql://xeno:xeno_secret@localhost:5432/xeno_crm"

# Redis (local Docker)
REDIS_URL="redis://localhost:6379"

# AI
OPENAI_API_KEY="sk-..."

# Channel service
CHANNEL_SERVICE_URL="http://localhost:4000"
WEBHOOK_BASE_URL="http://localhost:3000"   # CRM base URL — used by channel service for callbacks

# Security
WEBHOOK_SECRET="change-me-to-32-random-characters-min"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Production overrides ──────────────────────────────────────────────────────
# DATABASE_URL      → Supabase connection string (with ?pgbouncer=true&connection_limit=1)
# REDIS_URL         → Upstash Redis REST URL or Railway Redis URL
# CHANNEL_SERVICE_URL → https://channel-service.railway.app
# WEBHOOK_BASE_URL    → https://your-crm.vercel.app
# ─────────────────────────────────────────────────────────────────────────────

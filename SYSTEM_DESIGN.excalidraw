    { "id": "s2", "type": "rectangle", "x": 498, "y": 590, "width": 248, "height": 210, "angle": 0, "strokeColor": "#a78bfa", "backgroundColor": "#120830", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-s2", "type": "text", "x": 498, "y": 590, "width": 248, "height": 210, "angle": 0, "strokeColor": "#ddd6fe", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "📦 Stage 2\nProduct Agent\n─────────────\nCategory match\nVector similarity\n(cosine <=> ≥ 0.6)\nFallback: direct DB\nReturns:\n3 primary + 3 cross", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "📦 Stage 2\nProduct Agent\n─────────────\nCategory match\nVector similarity\n(cosine <=> ≥ 0.6)\nFallback: direct DB\nReturns:\n3 primary + 3 cross", "isDeleted": false, "groupIds": [] },


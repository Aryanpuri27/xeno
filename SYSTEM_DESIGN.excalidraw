    { "id": "launch", "type": "rectangle", "x": 1668, "y": 590, "width": 188, "height": 210, "angle": 0, "strokeColor": "#22c55e", "backgroundColor": "#031a0d", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-launch", "type": "text", "x": 1668, "y": 590, "width": 188, "height": 210, "angle": 0, "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "🚀 Launch\nCampaign\n──────────\nCreate Campaign\nrow in DB\n\nEnqueue N jobs\n(1 per customer)\ninto BullMQ", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "🚀 Launch\nCampaign\n──────────\nCreate Campaign\nrow in DB\n\nEnqueue N jobs\n(1 per customer)\ninto BullMQ", "isDeleted": false, "groupIds": [] },

    { "id": "t-states", "type": "text", "x": 108, "y": 824, "width": 1730, "height": 52, "angle": 0, "strokeColor": "#334155", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "OrchestratorRun.status state machine:\nRUNNING  →  AWAITING_SEGMENT_APPROVAL  →  AWAITING_PRODUCT_APPROVAL  →  AWAITING_CONTENT_APPROVAL  →  AWAITING_CHANNEL_APPROVAL  →  LAUNCHED", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "OrchestratorRun.status state machine:\nRUNNING  →  AWAITING_SEGMENT_APPROVAL  →  AWAITING_PRODUCT_APPROVAL  →  AWAITING_CONTENT_APPROVAL  →  AWAITING_CHANNEL_APPROVAL  →  LAUNCHED", "isDeleted": false, "groupIds": [] },

    { "id": "r-loop", "type": "rectangle", "x": 1878, "y": 590, "width": 224, "height": 330, "angle": 0, "strokeColor": "#6366f1", "backgroundColor": "#08081e", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-loop", "type": "text", "x": 1878, "y": 590, "width": 224, "height": 330, "angle": 0, "strokeColor": "#818cf8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "🔄 Learning Loop\n─────────────────\nAfter campaign\ncompletes:\n\nAnalytics Agent\naggregates CTR,\nopens, conversions\n\nGenerates embedding\n→ UPSERT into\nCampaignMemory\n\nFeeds Stage 1\non next run\n(pgvector RAG)", "fontSize": 11, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "🔄 Learning Loop\n─────────────────\nAfter campaign\ncompletes:\n\nAnalytics Agent\naggregates CTR,\nopens, conversions\n\nGenerates embedding\n→ UPSERT into\nCampaignMemory\n\nFeeds Stage 1\non next run\n(pgvector RAG)", "isDeleted": false, "groupIds": [] },


    { "id": "t-openai", "type": "text", "x": 2130, "y": 542, "width": 324, "height": 286, "angle": 0, "strokeColor": "#6ee7b7", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "🤖 OpenAI API\n─────────────────\nGPT-4o\n(orchestrator, content)\n\nGPT-4o-mini\n(segment SQL gen)\n(channel selector)\n\ntext-embedding-\nada-002\n(1536-dim vectors\nfor pgvector RAG)", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "🤖 OpenAI API\n─────────────────\nGPT-4o\n(orchestrator, content)\n\nGPT-4o-mini\n(segment SQL gen)\n(channel selector)\n\ntext-embedding-\nada-002\n(1536-dim vectors\nfor pgvector RAG)", "isDeleted": false, "groupIds": [] },

    { "id": "r-queue", "type": "rectangle", "x": 80, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#ef4444", "backgroundColor": "#1a0202", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-queue", "type": "text", "x": 80, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "🔴 Redis + BullMQ Queue\n───────────────────────\nQueue: campaign-send\n1 job per customer\n\nIdempotency key (24h TTL)\nidem:<campaignId>:<custId>\n\nSSE event bus (in-memory)", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "🔴 Redis + BullMQ Queue\n───────────────────────\nQueue: campaign-send\n1 job per customer\n\nIdempotency key (24h TTL)\nidem:<campaignId>:<custId>\n\nSSE event bus (in-memory)", "isDeleted": false, "groupIds": [] },

    { "id": "r-worker", "type": "rectangle", "x": 542, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#f59e0b", "backgroundColor": "#1a0e00", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-worker", "type": "text", "x": 542, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#fcd34d", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "⚙️ BullMQ Worker\n───────────────────────\nStandalone Node.js process\nConcurrency: 20 jobs\nRate limit: 100 jobs/sec\n\n1. Check idempotency key\n2. INSERT Communication (SENT)\n3. POST → Channel Service\n4. Mark idem key in Redis", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "⚙️ BullMQ Worker\n───────────────────────\nStandalone Node.js process\nConcurrency: 20 jobs\nRate limit: 100 jobs/sec\n\n1. Check idempotency key\n2. INSERT Communication (SENT)\n3. POST → Channel Service\n4. Mark idem key in Redis", "isDeleted": false, "groupIds": [] },

    { "id": "r-channel", "type": "rectangle", "x": 1004, "y": 1022, "width": 420, "height": 168, "angle": 0, "strokeColor": "#22c55e", "backgroundColor": "#021a0d", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-channel", "type": "text", "x": 1004, "y": 1022, "width": 420, "height": 168, "angle": 0, "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "📱 Channel Service  (port 4000)\n────────────────────────────\nExpress micro-service\nPOST /send  ·  GET /health\n\nDelivery rates by channel:\nWhatsApp 88%  ·  Email 72%\nSMS 80%  ·  RCS 75%\n\nSigns callbacks: HMAC-SHA256", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "📱 Channel Service  (port 4000)\n────────────────────────────\nExpress micro-service\nPOST /send  ·  GET /health\n\nDelivery rates by channel:\nWhatsApp 88%  ·  Email 72%\nSMS 80%  ·  RCS 75%\n\nSigns callbacks: HMAC-SHA256", "isDeleted": false, "groupIds": [] },

    { "id": "r-cascade", "type": "rectangle", "x": 1498, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#ec4899", "backgroundColor": "#200414", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-cascade", "type": "text", "x": 1498, "y": 1022, "width": 390, "height": 168, "angle": 0, "strokeColor": "#f9a8d4", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "📬 Async Webhook Cascade\n────────────────────────────\nDELIVERED   0.8 – 3 s\n→ OPENED     60%  ·  5 – 30 s\n→ CLICKED    30%  ·  3 – 15 s\n→ CONVERTED  15%  ·  10 – 60 s\n\nFired → POST /api/webhook/receipt\nNon-delivered: FAILED / BOUNCED", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "📬 Async Webhook Cascade\n────────────────────────────\nDELIVERED   0.8 – 3 s\n→ OPENED     60%  ·  5 – 30 s\n→ CLICKED    30%  ·  3 – 15 s\n→ CONVERTED  15%  ·  10 – 60 s\n\nFired → POST /api/webhook/receipt\nNon-delivered: FAILED / BOUNCED", "isDeleted": false, "groupIds": [] },

    { "id": "r-sweep", "type": "rectangle", "x": 1960, "y": 1022, "width": 340, "height": 168, "angle": 0, "strokeColor": "#6366f1", "backgroundColor": "#0a0a24", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-sweep", "type": "text", "x": 1960, "y": 1022, "width": 340, "height": 168, "angle": 0, "strokeColor": "#818cf8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "🧹 Stale Sweep\n───────────────────\nPeriodic background job\nScans SENT rows stuck\n> staleThreshold\n→ marks FAILED\n→ triggers campaign\ncompletion check", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "🧹 Stale Sweep\n───────────────────\nPeriodic background job\nScans SENT rows stuck\n> staleThreshold\n→ marks FAILED\n→ triggers campaign\ncompletion check", "isDeleted": false, "groupIds": [] },


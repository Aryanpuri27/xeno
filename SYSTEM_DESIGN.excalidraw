    { "id": "s1", "type": "rectangle", "x": 108, "y": 590, "width": 248, "height": 210, "angle": 0, "strokeColor": "#38bdf8", "backgroundColor": "#062030", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },

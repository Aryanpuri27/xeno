    { "id": "r-prisma", "type": "rectangle", "x": 1360, "y": 278, "width": 310, "height": 176, "angle": 0, "strokeColor": "#475569", "backgroundColor": "#060c18", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },

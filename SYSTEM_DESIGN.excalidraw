    { "id": "s4", "type": "rectangle", "x": 1278, "y": 590, "width": 248, "height": 210, "angle": 0, "strokeColor": "#f97316", "backgroundColor": "#1e0800", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "roundness": { "type": 3 }, "isDeleted": false, "groupIds": [] },
    { "id": "t-s4", "type": "text", "x": 1278, "y": 590, "width": 248, "height": 210, "angle": 0, "strokeColor": "#fed7aa", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "📡 Stage 4\nChannel Agent\n─────────────\nHistoric CTR query\nGPT-4o-mini selects\nWhatsApp / Email\nSMS / RCS\nReturns:\nchannel + confidence", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "📡 Stage 4\nChannel Agent\n─────────────\nHistoric CTR query\nGPT-4o-mini selects\nWhatsApp / Email\nSMS / RCS\nReturns:\nchannel + confidence", "isDeleted": false, "groupIds": [] },

